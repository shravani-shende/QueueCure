PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/hospital_queue?retryWrites=true&w=majority
MONGODB_DB=hospital_queue
HOSPITAL_NAME=City Care Hospital
ADMIN_EMAIL=admin@hospital.test
ADMIN_PASSWORD=ChangeMe@123
PUBLIC_APP_URL=https://your-demo-domain.example.com

# Set this only if the frontend is deployed separately from the API.
# If the Express server serves the built frontend, leave it unset.
VITE_API_URL=https://your-api-domain.example.com/api

# WhatsApp Cloud API sends the QR as an image attachment.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_NAME=hospital_queue_qr
WHATSAPP_TEMPLATE_LANGUAGE=en

# Twilio sends the one-minute "get ready" SMS. Use an E.164 sender number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+10000000000
